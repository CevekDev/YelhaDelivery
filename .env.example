# ============================================
# YelhaDelivery — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# ============================================

# --- Supabase ---
# Récupère ces valeurs dans : Project Settings → API (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : NE JAMAIS exposer côté client. Utilisé uniquement côté serveur (Server Actions admin).
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (stockage des images de menu) ---
# Si NON configuré, fallback automatique vers Supabase Storage.
# Crée un bucket sur https://dash.cloudflare.com/?to=/:account/r2/new
# Puis active "Public access" et crée un API token (Object Read & Write).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yelha-dms-images
# URL publique du bucket (custom domain OU pub-xxxxx.r2.dev)
R2_PUBLIC_URL=

# --- Resend (emails transactionnels) ---
# Crée un compte sur https://resend.com puis vérifie ton domaine yelha.net
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yelha.net

# --- Upstash Redis (rate limiting distribué) ---
# Optionnel mais recommandé en prod (Vercel multi-instances). Si vide → repli
# automatique sur un limiteur en mémoire (par instance).
# Crée une base sur https://console.upstash.com (Redis) → onglet "REST API".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Web Push (notifications « nouvelle commande » resto + livreur) ---
# Génère une paire de clés VAPID : npx web-push generate-vapid-keys
# (ou node -e "console.log(require('web-push').generateVAPIDKeys())")
# Si vide → les notifications push sont simplement désactivées (rien ne casse).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@yelha.net

# --- App ---
NEXT_PUBLIC_APP_URL=https://delivery.yelha.net
NEXT_PUBLIC_APP_NAME=YelhaDelivery

# --- Admin initial (utilisé uniquement par le seed) ---
# Après le premier login, change ce mot de passe via l'interface
ADMIN_EMAIL=
ADMIN_PASSWORD=
